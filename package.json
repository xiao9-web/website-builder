{
  "name": "website-builder",
  "version": "1.0.0",
  "description": "可视化官网构建系统，支持一键部署到阿里云",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd apps/web && npm install",
    "dev:server": "DB_USERNAME=wb_user DB_PASSWORD=wb_pass mvn -f apps/server/pom.xml spring-boot:run",
    "dev:web": "cd apps/web && npm run dev",
    "build:server": "mvn -f apps/server/pom.xml -DskipTests package",
    "build:web": "cd apps/web && npm run build",
    "build:all": "npm run build:server && npm run build:web",
    "start:server": "DB_USERNAME=wb_user DB_PASSWORD=wb_pass java -jar apps/server/target/website-builder-0.1.0-SNAPSHOT.jar",
    "lint": "npm run lint:web",
    "lint:web": "cd apps/web && npm run lint"
  },
  "keywords": [
    "website-builder",
    "cms",
    "static-site-generator",
    "aliyun-oss",
    "nextjs",
    "spring-boot"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}

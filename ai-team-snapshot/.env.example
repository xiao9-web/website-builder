# 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# GitHub配置
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_username

# Claude API配置（如果需要）
ANTHROPIC_API_KEY=your_api_key_here

# 内部API配置（如果有）
INTERNAL_API_KEY=your_internal_api_key
INTERNAL_DB_URL=your_database_url

# 其他配置
NODE_ENV=development
LOG_LEVEL=info

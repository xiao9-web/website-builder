# 服务配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=website_builder

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 阿里云OSS配置
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_REGION=oss-cn-shenzhen
ALIYUN_OSS_BUCKET=your_bucket_name
ALIYUN_OSS_DOMAIN=your_oss_domain.com

# 阿里云CDN配置（可选）
ALIYUN_CDN_DOMAIN=your_cdn_domain.com
ALIYUN_CDN_ACCESS_KEY_ID=your_cdn_access_key_id
ALIYUN_CDN_ACCESS_KEY_SECRET=your_cdn_access_key_secret

# 管理员初始账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

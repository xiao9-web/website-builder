# Blog System Environment Variables
# Copy to .env and fill in production values

# PostgreSQL
BLOG_DB_NAME=blog
BLOG_DB_USER=blog_user
BLOG_DB_PASSWORD=blog_pass
BLOG_DB_PORT=5433

# Redis
BLOG_REDIS_PASSWORD=redis_pass
BLOG_REDIS_PORT=6380

# Spring Boot
BLOG_PROFILE=prod
BLOG_SERVER_PORT=8080
BLOG_JWT_SECRET=change-me-in-production
BLOG_JWT_ACCESS_EXP=3600
BLOG_JWT_REFRESH_EXP=604800

# Nginx
BLOG_HTTP_PORT=80
BLOG_HTTPS_PORT=443
